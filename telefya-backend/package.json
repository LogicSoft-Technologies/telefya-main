{
  "name": "ludo-backend",
  "version": "1.0.0",
  "main": "index.js",
  "engines": {
    "node": ">=22.14.0",
    "npm": ">=10.8.2"
  },
  "scripts": {
    "test": "jest --detectOpenHandles --forceExit",
    "test:coverage": "jest --coverage --detectOpenHandles --forceExit",
    "start": "node index.js",
    "dev": "nodemon index.js",
    "local": "nodemon server.js",
    "mkcert": "mkcert create-ca --cert .cert/ca.crt --key .cert/ca.key && mkcert create-cert --ca-cert .cert/ca.crt --ca-key .cert/ca.key --cert .cert/cert.crt --key .cert/cert.key"
  },
  "jest": {
    "collectCoverageFrom": [
      "services/**/*.js",
      "controllers/**/*.js",
      "routes/**/*.js",
      "!**/node_modules/**",
      "!tests/**"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": [
      "text",
      "lcov"
    ],
    "testEnvironment": "node"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "description": "",
  "dependencies": {
    "@socket.io/redis-adapter": "^8.3.0",
    "aws-sdk": "^2.1692.0",
    "axios": "^1.7.9",
    "bcrypt": "^5.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.1.0",
    "image-size": "^2.0.2",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "mediasoup": "^3.21.0",
    "memory-cache": "^0.2.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.15.3",
    "nodemailer": "^7.0.12",
    "playwright": "^1.61.1",
    "puppeteer-core": "^24.31.0",
    "redis": "^5.7.0",
    "rotating-file-stream": "^3.2.6",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "stream-chat": "^8.55.0",
    "stripe": "^22.3.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^13.0.0",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.9",
    "rimraf": "^6.0.1",
    "supertest": "^7.0.0",
    "ts-node": "^10.9.2"
  },
  "allowScripts": {
    "bcrypt@5.1.1": true,
    "sharp@0.34.5": true,
    "aws-sdk@2.1693.0": true,
    "@scarf/scarf@1.4.0": true,
    "mediasoup@3.20.10": true
  }
}
