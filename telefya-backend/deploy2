#!/bin/bash

# Configuration variables
COMMIT_MESSAGE="$1"
APP_NAME="bww-app-api"
USER="administrator"
REMOTE_IP="63.141.255.177"
REMOTE_PATH="/home/bww-api"
BWWUSER="bww-api"
SSH_KEY_PATH="D://ludo-data/ludo"

# Validate configuration
if [[ -z "$REMOTE_IP" ]]; then
    error_exit "REMOTE_IP must be set"
fi

if [[ ! -f "$SSH_KEY_PATH" ]]; then
    error_exit "SSH key not found at $SSH_KEY_PATH"
fi

error_exit() {
    echo "Error: $1" >&2
    exit "${2:-1}"
}

setup() {
    # Validate commit message
    if [[ -z "$COMMIT_MESSAGE" ]]; then
        error_exit "Usage: $0 'commit message'" 1
    fi

    echo "Starting secure deployment process..."

    # Initialize SSH agent
    eval "$(ssh-agent -s)" || error_exit "Failed to start SSH agent"
    ssh-add "$SSH_KEY_PATH" || error_exit "Failed to add SSH key"

    # Clean up old archives
    rm -f *.tar.gz 2>/dev/null || true

    # Create tar archive with secure exclusions
    echo "Creating secure archive..."
    echo "Current directory: $(pwd)"
    echo "Files in current directory:"
    ls -la | head -10
    
    sleep 2
    
    # Create exclusion file for better handling
    cat > /tmp/exclude_list.txt << 'EXCLUDE_EOF'
node_modules
.cert
.git
coverage
*.tar.gz
deploy
logs
*.log
.npm
.cache
tmp
temp
.DS_Store
Thumbs.db
package-lock.json
.env*
*.key
*.pem
*.p12
secrets
config/production.json
EXCLUDE_EOF

    echo "Creating archive with exclusions..."
    if tar --exclude-from=/tmp/exclude_list.txt \
           --warning=no-file-changed \
           --warning=no-file-removed \
           -czf "${APP_NAME}.tar.gz" . ; then
        echo "✓ Archive created successfully"
    else
        echo "❌ Tar command failed. Trying alternative method..."
        if tar -czf "${APP_NAME}.tar.gz" \
               --exclude='node_modules' \
               --exclude='.git' \
               --exclude='*.tar.gz' \
               --exclude='.env' \
               --exclude='logs' \
               --exclude='*.log' \
               . ; then
            echo "✓ Archive created with basic exclusions"
        else
            echo "❌ Both archive methods failed. Checking permissions and files..."
            echo "Current user: $(whoami)"
            echo "Current directory permissions:"
            ls -ld .
            echo "Checking for problematic files..."
            find . -maxdepth 2 -type f ! -readable 2>/dev/null || true
            rm -f /tmp/exclude_list.txt
            error_exit "Failed to create archive - please check file permissions and try again"
        fi
    fi
    
    # Clean up
    rm -f /tmp/exclude_list.txt

    # Verify archive was created
    if [[ ! -f "${APP_NAME}.tar.gz" ]]; then
        error_exit "Archive was not created"
    fi

    # Test SSH connection
    echo "Testing SSH connection..."
    ssh -i "$SSH_KEY_PATH" -o ConnectTimeout=10 "${USER}@${REMOTE_IP}" "echo 'SSH connection successful'" || error_exit "SSH connection failed"

    # Upload to server
    echo "Uploading to server..."
    scp -i "$SSH_KEY_PATH" "${APP_NAME}.tar.gz" "${USER}@${REMOTE_IP}:/tmp/" || error_exit "Failed to upload archive"

    # Remote deployment
    echo "Executing secure remote deployment..."
    ssh -i "$SSH_KEY_PATH" "${USER}@${REMOTE_IP}" bash -s << 'EOF'
        set -euo pipefail  # Enable strict error handling

        # Security: Set restrictive umask
        umask 027

        # Import variables from local environment
        APP_NAME="bww-app-api"
        REMOTE_PATH="/home/bww-api"
        BWWUSER="bww-api"
        USER="administrator"

        # Function to setup user and group securely
        setup_user_group() {
            echo "Setting up user and group..."
            
            if [[ -z "${BWWUSER}" ]] || [[ "${BWWUSER}" =~ [^a-zA-Z0-9_-] ]]; then
                echo "ERROR: BWWUSER variable is not set or contains invalid characters."
                exit 1
            fi

            if ! getent group "${BWWUSER}" &>/dev/null; then
                echo "Creating group: ${BWWUSER}"
                sudo groupadd "${BWWUSER}" || { echo "Failed to create group ${BWWUSER}"; exit 1; }
                echo "✓ Group ${BWWUSER} created successfully"
            else
                echo "✓ Group ${BWWUSER} already exists"
            fi

            if ! id "${BWWUSER}" &>/dev/null; then
                echo "Creating user: ${BWWUSER}"
                sudo useradd -r -g "${BWWUSER}" -d "/home/${BWWUSER}" -m -s /bin/bash "${BWWUSER}" || { echo "Failed to create user ${BWWUSER}"; exit 1; }
                echo "✓ User ${BWWUSER} created successfully"
            else
                echo "✓ User ${BWWUSER} already exists"
            fi

            sudo chown "${BWWUSER}:${BWWUSER}" "/home/${BWWUSER}" || { echo "Failed to set home directory ownership"; exit 1; }
            sudo chmod 755 "/home/${BWWUSER}" || { echo "Failed to set home directory permissions"; exit 1; }

            if ! groups "${USER}" | grep -q "${BWWUSER}"; then
                sudo usermod -aG "${BWWUSER}" "${USER}" || { echo "Failed to add ${USER} to ${BWWUSER} group"; exit 1; }
                echo "✓ Added ${USER} to ${BWWUSER} group"
            else
                echo "✓ ${USER} already in ${BWWUSER} group"
            fi
        }

        install_nginx() {
            if ! command -v nginx &>/dev/null; then
                echo "Installing Nginx..."
                sudo apt-get update || { echo "Failed to update apt"; exit 1; }
                sudo apt-get install -y nginx || { echo "Failed to install nginx"; exit 1; }
                echo "Nginx installed"
            else
                echo "✓ Nginx already installed"
            fi

            # Remove conflicting configurations
            echo "Checking for conflicting server_name configurations..."
            sudo find /etc/nginx/sites-available -type f -exec grep -l "server_name meet.bornwithwealth.com" {} \; | while read -r file; do
                if [[ "$file" != "/etc/nginx/sites-available/bww-app" ]]; then
                    echo "Removing conflicting configuration: $file"
                    sudo rm -f "$file"
                fi
            done
            sudo find /etc/nginx/sites-enabled -type f -exec grep -l "server_name meet.bornwithwealth.com" {} \; | while read -r file; do
                if [[ "$file" != "/etc/nginx/sites-enabled/bww-app" ]]; then
                    echo "Removing conflicting enabled configuration: $file"
                    sudo rm -f "$file"
                fi
            done
            sudo rm -f /etc/nginx/sites-enabled/default 2>/dev/null || true
            sudo rm -f /etc/nginx/sites-enabled/meet.bornwithwealth.com 2>/dev/null || true
            sudo rm -f /etc/nginx/sites-enabled/bww-api 2>/dev/null || true
            sudo rm -f /etc/nginx/sites-available/bww-api 2>/dev/null || true

            # Check and fix nginx.conf for incorrect includes
            echo "Checking nginx.conf for incorrect includes..."
            if grep -q "bww-api" /etc/nginx/nginx.conf; then
                echo "Replacing bww-api with bww-app in nginx.conf..."
                sudo sed -i 's|bww-api|bww-app|g' /etc/nginx/nginx.conf || { echo "Failed to update nginx.conf"; exit 1; }
            fi

            # Ensure sites-enabled is included in nginx.conf
            if ! grep -q 'include /etc/nginx/sites-enabled' /etc/nginx/nginx.conf; then
                echo "Adding sites-enabled include to nginx.conf..."
                sudo sed -i '/http\s*{/,/}/ s/^\(\s*\)}/\1    include \/etc\/nginx\/sites-enabled\/*;\n\1}/' /etc/nginx/nginx.conf || { echo "Failed to modify nginx.conf"; exit 1; }
            fi

            create_nginx_config

            # Verify symbolic link
            if [[ ! -L "/etc/nginx/sites-enabled/bww-app" ]] || [[ ! -f "/etc/nginx/sites-available/bww-app" ]]; then
                echo "Creating symbolic link for bww-app..."
                sudo ln -sf /etc/nginx/sites-available/bww-app /etc/nginx/sites-enabled/bww-app || { echo "Failed to create symbolic link"; exit 1; }
            fi

            # Test and restart Nginx
            sudo nginx -t || { echo "Nginx configuration test failed"; exit 1; }
            sudo systemctl restart nginx || { echo "Failed to restart nginx"; exit 1; }
            sudo systemctl enable nginx || { echo "Failed to enable nginx"; exit 1; }
            echo "✓ Nginx configured and restarted"
        }





create_nginx_config() {
    
            echo "Creating secure Nginx configuration..."
            sudo tee /etc/nginx/sites-available/bww-app > /dev/null << 'NGINX_CONF'
            limit_req_zone $binary_remote_addr zone=api:10m rate=10r/s;
            limit_req_zone $binary_remote_addr zone=websocket:10m rate=5r/s;

upstream bww_backend {
    server 127.0.0.1:5000 max_fails=3 fail_timeout=30s;
}

server {
    listen 80;
    server_name meet.bornwithwealth.com;
    add_header X-Frame-Options "DENY" always;
    add_header X-Content-Type-Options "nosniff" always;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name meet.bornwithwealth.com;

    ssl_certificate /etc/letsencrypt/live/bornwithwealth.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/bornwithwealth.com/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384;
    ssl_prefer_server_ciphers off;
    ssl_session_cache shared:SSL:10m;
    ssl_session_timeout 1d;
    ssl_session_tickets off;
    # ssl_stapling on;
    # ssl_stapling_verify on;

    add_header Strict-Transport-Security "max-age=63072000; includeSubDomains; preload" always;
    add_header X-Frame-Options "DENY" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-XSS-Protection "1; mode=block" always;
    add_header Referrer-Policy "no-referrer-when-downgrade" always;
    add_header Content-Security-Policy "default-src 'self' https:; script-src 'self' 'unsafe-inline' https:; style-src 'self' 'unsafe-inline' https:; img-src 'self' data: https:; connect-src 'self' wss: https:;" always;

    root /home/bww-web;
    index index.html;
    server_tokens off;

    location / {
        try_files $uri $uri/ /index.html;
        location ~* \.(js|css|png|jpg|jpeg|gif|ico|svg)$ {
            expires 1y;
            add_header Cache-Control "public, immutable";
        }
    }

    location /socket.io/ {
        #limit_req zone=websocket burst=10 nodelay;
        proxy_pass http://bww_backend;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_connect_timeout 60s;
        proxy_send_timeout 60s;
        proxy_read_timeout 300s;
    }

    location ~ ^/(class_meeting|conf_meeting) {
        limit_req zone=api burst=5 nodelay;
        proxy_pass http://bww_backend;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /images2/ {
        client_max_body_size 10M;
        proxy_pass http://bww_backend/images2/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /api/v2 {
        limit_req zone=api burst=20 nodelay;
        proxy_pass http://bww_backend/api/v2;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_pass_header Set-Cookie;
        proxy_cache_bypass $http_upgrade;
        client_max_body_size 5M;
    }

    location ~ /\. {
        deny all;
        access_log off;
        log_not_found off;
    }
    
    location ~ ^/(\.env|config/|\.git) {
        deny all;
        access_log off;
        log_not_found off;
    }
}
NGINX_CONF

            sudo ln -sf /etc/nginx/sites-available/bww-app /etc/nginx/sites-enabled/bww-app || { echo "Failed to enable Nginx site"; exit 1; }
            sudo nginx -t || { echo "Nginx configuration test failed"; exit 1; }
            echo "✓ Nginx configuration created and tested successfully"
        }

        setup_nodejs_npm_pm2() {
            echo "Setting up Node.js, npm, and PM2..."
            
            if ! command -v node &>/dev/null; then
                echo "Installing Node.js..."
                curl -fsSL https://deb.nodesource.com/setup_22.x | sudo bash - || { echo "Failed to setup Node.js"; exit 1; }
                sudo apt-get update && sudo apt-get install -y nodejs || { echo "Failed to install Node.js"; exit 1; }
            else
                echo "✓ Node.js already installed"
            fi

            if ! command -v pm2 &>/dev/null; then
                echo "Installing PM2..."
                sudo npm install -g pm2@latest || { echo "Failed to install PM2"; exit 1; }
            else
                echo "✓ PM2 already installed"
            fi
            
            echo "✓ Node.js and PM2 setup completed"
        }

        prepare_application() {
            echo "Preparing application..."
            
            if [[ ! -d "${REMOTE_PATH}" ]]; then
                sudo mkdir -p "${REMOTE_PATH}" || { echo "Failed to create remote directory"; exit 1; }
            fi
            
            sudo chown -R "${BWWUSER}:${BWWUSER}" "${REMOTE_PATH}" || { echo "Failed to set directory ownership"; exit 1; }
            sudo chmod 755 "${REMOTE_PATH}" || { echo "Failed to set directory permissions"; exit 1; }
            
            cd "${REMOTE_PATH}" || { echo "Failed to change to ${REMOTE_PATH}"; exit 1; }
            
            sudo mv "/tmp/${APP_NAME}.tar.gz" "${REMOTE_PATH}/" || { echo "Failed to move archive"; exit 1; }
            sudo chown "${BWWUSER}:${BWWUSER}" "${REMOTE_PATH}/${APP_NAME}.tar.gz" || { echo "Failed to set archive ownership"; exit 1; }
            
            sudo -u "${BWWUSER}" find . -maxdepth 1 -not -name "${APP_NAME}.tar.gz" -not -name '.' -not -name '..' -exec rm -rf {} + 2>/dev/null || true
            
            echo "Extracting archive..."
            sudo -u "${BWWUSER}" tar -xzf "${APP_NAME}.tar.gz" || { echo "Failed to extract archive"; exit 1; }
            sudo -u "${BWWUSER}" rm -f "${APP_NAME}.tar.gz"
            
            echo "Installing dependencies..."
            sudo -u "${BWWUSER}" mv .env-production .env 2>/dev/null || true
            sudo -u "${BWWUSER}" npm install --production || { echo "Failed to install dependencies"; exit 1; }
            
            sudo chown -R "${BWWUSER}:${BWWUSER}" "${REMOTE_PATH}"
            sudo find "${REMOTE_PATH}" -type d -exec chmod 755 {} \;
            sudo find "${REMOTE_PATH}" -type f -exec chmod 644 {} \;
            sudo find "${REMOTE_PATH}" -name "*.js" -exec chmod 755 {} \;
            sudo find "${REMOTE_PATH}" -name ".env*" -exec chmod 600 {} \; 2>/dev/null || true
            sudo chmod +x "${REMOTE_PATH}/node_modules/mediasoup/worker/out/Release/mediasoup-worker" 2>/dev/null || true

            echo "✓ Application prepared successfully"
        }

        initialize_pm2_for_user() {
            echo "Initializing PM2 for user ${BWWUSER}..."
            sudo -u "${BWWUSER}" mkdir -p "/home/${BWWUSER}/.pm2/logs" || { echo "Failed to create PM2 logs directory"; exit 1; }
            sudo -u "${BWWUSER}" mkdir -p "/home/${BWWUSER}/.pm2/pids" || { echo "Failed to create PM2 pids directory"; exit 1; }
        }


start_services() {
            echo "Starting services..."
            
            sudo nginx -t || { echo "Nginx configuration is invalid"; exit 1; }
            sudo systemctl restart nginx || { echo "Failed to restart nginx"; exit 1; }
            sudo systemctl enable nginx || { echo "Failed to enable nginx"; exit 1; }

            sleep 3

            # Kill any existing PM2 processes or port conflicts
            if sudo lsof -ti:5000; then
                sudo lsof -ti:5000 | sudo xargs kill -9 || { echo "Failed to kill processes on port 5000"; exit 1; }
                echo "✓ Killed processes on port 5000"
            fi

            if sudo -u "${BWWUSER}" lsof -ti:5000; then
                sudo -u "${BWWUSER}" lsof -ti:5000 | sudo -u "${BWWUSER}" xargs kill -9 || { echo "Failed to kill processes on port 5000"; exit 1; }
                echo "✓ Killed user processes on port 5000"
            fi
            
         
            
            echo "✓ PM2 initialized successfully for user '${BWWUSER}'"

            # Start PM2 process with correct paths and environment
            echo "Starting PM2 application..."
            sudo -u "${BWWUSER}" bash -c "
                export HOME='/home/${BWWUSER}'
                export PM2_HOME='/home/${BWWUSER}/.pm2'
                cd '${REMOTE_PATH}' || { echo 'Failed to change to application directory'; exit 1; }
                
                # Delete existing process if it exists
                pm2 delete '${APP_NAME}-runner' 2>/dev/null || true
                
                # Verify index.js exists
                if [[ ! -f 'index.js' ]]; then
                    echo 'Error: index.js not found in ${REMOTE_PATH}'
                    ls -la
                    exit 1
                fi
                
                # Start the application
                pm2 start 'index.js' --name '${APP_NAME}-runner' -i 1 || { 
                    echo 'Failed to start PM2 process'
                    echo 'PM2 status:'
                    pm2 status || true
                    echo 'Application directory contents:'
                    ls -la '${REMOTE_PATH}' || true
                    exit 1
                }
                
                # Save PM2 configuration
                
                
                echo '✓ PM2 application started successfully'
            " || error_exit "Failed to start PM2 services"

            # Setup PM2 startup (run as root to modify system files)
            sudo env PATH=$PATH:/usr/bin pm2 startup systemd -u "${BWWUSER}" --hp "/home/${BWWUSER}" || { 
                echo "Warning: PM2 startup configuration may have failed, but continuing..."; 
            }
            
            pm2 save || { echo 'Failed to save PM2 configuration'; exit 1; }

            echo "✅ Services started successfully!"
            echo ""
            echo "📊 Service Status:"
            echo "1. Nginx: $(sudo systemctl is-active nginx)"
            echo "2. PM2 Status:"
            sudo -u "${BWWUSER}" bash -c "export PM2_HOME='/home/${BWWUSER}/.pm2'; pm2 status" || true
            echo ""
            echo "📝 Useful Commands:"
            echo "1. Check PM2 status: sudo -u ${BWWUSER} bash -c 'export PM2_HOME=\"/home/${BWWUSER}/.pm2\"; pm2 status'"
            echo "2. Check logs: sudo -u ${BWWUSER} bash -c 'export PM2_HOME=\"/home/${BWWUSER}/.pm2\"; pm2 logs ${APP_NAME}-runner'"
            echo "3. Monitor system: sudo -u ${BWWUSER} bash -c 'export PM2_HOME=\"/home/${BWWUSER}/.pm2\"; pm2 monit'"
            echo "4. Restart app: sudo -u ${BWWUSER} bash -c 'export PM2_HOME=\"/home/${BWWUSER}/.pm2\"; pm2 restart ${APP_NAME}-runner'"
        }

        # Execute deployment steps in order
        setup_user_group
        setup_nodejs_npm_pm2
        install_nginx
        prepare_application
        start_services

        echo "✓ Remote deployment completed successfully"
EOF

    echo "Cleaning up local archive..."
    rm -f "${APP_NAME}.tar.gz"
    echo "✅ Deployment finished successfully!"
}

send_to_github() {
    if [[ -z "$COMMIT_MESSAGE" ]]; then
        error_exit "No commit message provided for GitHub"
    fi
    
    echo "📤 Pushing to GitHub..."
    
    if git diff-index --quiet HEAD --; then
        echo "No changes to commit"
        return 0
    fi
    
    git add . || error_exit "Git add failed"
    git commit -m "$COMMIT_MESSAGE" || error_exit "Git commit failed"
    git push || error_exit "Git push failed"
    
    echo "✅ Successfully pushed to GitHub"
}

main() {
    echo "🚀 Starting secure deployment process..."
    echo "Commit message: $COMMIT_MESSAGE"
    echo "Target server: $REMOTE_IP"
    echo "Application: $APP_NAME"
    echo ""
    
    setup
    send_to_github
    
    echo ""
    echo "🎉 Deployment process completed successfully!"
    echo "Visit: https://meet.bornwithwealth.com to verify the deployment"
}

main "$@"